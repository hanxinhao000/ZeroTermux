{
  "name": "VS Code Dark+",
  "settings": [
    {
      "settings": {
        "background": "#1E1E1E",
        "foreground": "#D4D4D4",
        "caret": "#AEAFAD",
        "lineHighlight": "#2A2D2E",
        "selection": "#264F78",
        "invisibles": "#3B3B3B",
        "guide": "#404040",
        "highlightedDelimetersForeground": "#FFD700"
      }
    },
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6A9955"
      }
    },
    {
      "name": "Documentation Comment",
      "scope": [
        "comment.block.documentation",
        "comment.documentation",
        "storage.type.class.jsdoc",
        "entity.name.type.instance.jsdoc",
        "variable.other.jsdoc"
      ],
      "settings": {
        "foreground": "#6A9955"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier",
        "keyword.control",
        "keyword.other",
        "keyword.local.lua"
      ],
      "settings": {
        "foreground": "#569CD6"
      }
    },
    {
      "name": "Operator and Punctuation",
      "scope": [
        "keyword.operator",
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#D4D4D4"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#CE9178"
      }
    },
    {
      "name": "String Escape",
      "scope": [
        "constant.character.escape",
        "constant.character.string.escape",
        "string.regexp keyword.operator",
        "string.regexp constant.character.escape"
      ],
      "settings": {
        "foreground": "#D7BA7D"
      }
    },
    {
      "name": "Number and Boolean",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#B5CEA8"
      }
    },
    {
      "name": "Language Constants",
      "scope": [
        "constant.language",
        "support.constant",
        "variable.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#569CD6"
      }
    },
    {
      "name": "Class Interface Namespace",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "support.type.primitive",
        "meta.type.annotation",
        "meta.return.type"
      ],
      "settings": {
        "foreground": "#4EC9B0"
      }
    },
    {
      "name": "Function and Method",
      "scope": [
        "entity.name.function",
        "support.function",
        "support.function.builtin",
        "meta.function-call",
        "meta.method-call",
        "variable.function",
        "function-declaration",
        "method-declaration"
      ],
      "settings": {
        "foreground": "#DCDCAA"
      }
    },
    {
      "name": "Variable and Parameter",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter",
        "meta.definition.variable.name",
        "operator.rest.parameters"
      ],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },
    {
      "name": "Property and Field",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "variable.object.property",
        "support.variable.property",
        "meta.object-literal.key",
        "meta.property-name",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },
    {
      "name": "Annotation and Decorator",
      "scope": [
        "meta.annotation",
        "punctuation.definition.annotation",
        "storage.type.annotation",
        "meta.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#DCDCAA"
      }
    },
    {
      "name": "Java Kotlin Package Import",
      "scope": [
        "storage.modifier.import.java",
        "storage.modifier.package.java",
        "keyword.other.import.kotlin",
        "keyword.other.package.kotlin"
      ],
      "settings": {
        "foreground": "#C586C0"
      }
    },
    {
      "name": "Control Flow",
      "scope": [
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.flow",
        "keyword.control.trycatch",
        "keyword.control.exception",
        "keyword.control.return",
        "keyword.control.import",
        "keyword.control.export"
      ],
      "settings": {
        "foreground": "#C586C0"
      }
    },
    {
      "name": "Python Self and Builtins",
      "scope": [
        "variable.parameter.function.language.special.self.python",
        "variable.language.special.self.python",
        "support.type.python",
        "support.function.builtin.python"
      ],
      "settings": {
        "foreground": "#569CD6"
      }
    },
    {
      "name": "JavaScript Builtins",
      "scope": [
        "support.type.object.module.js",
        "support.type.object.console.js",
        "support.class.promise.js",
        "support.constant.math.js",
        "support.variable.property.dom.js"
      ],
      "settings": {
        "foreground": "#4EC9B0"
      }
    },
    {
      "name": "HTML XML Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "punctuation.definition.tag",
        "punctuation.definition.tag.html",
        "punctuation.definition.tag.xml"
      ],
      "settings": {
        "foreground": "#569CD6"
      }
    },
    {
      "name": "HTML XML Attribute",
      "scope": [
        "entity.other.attribute-name",
        "meta.attribute"
      ],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },
    {
      "name": "HTML XML Entity",
      "scope": [
        "constant.character.entity",
        "punctuation.definition.entity"
      ],
      "settings": {
        "foreground": "#D7BA7D"
      }
    },
    {
      "name": "Markdown Heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#569CD6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": "markup.bold",
      "settings": {
        "foreground": "#D4D4D4",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": "markup.italic",
      "settings": {
        "foreground": "#D4D4D4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Link",
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "meta.link.inline",
        "meta.link.reference"
      ],
      "settings": {
        "foreground": "#CE9178"
      }
    },
    {
      "name": "Markdown Code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#CE9178"
      }
    },
    {
      "name": "JSON Property Name",
      "scope": [
        "support.type.property-name.json",
        "support.type.property-name.json.comments",
        "meta.structure.dictionary.json string.quoted.double.json support.type.property-name.json",
        "meta.structure.dictionary.json.comments string.quoted.double.json.comments support.type.property-name.json.comments"
      ],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },
    {
      "name": "JSON String Value",
      "scope": [
        "string.quoted.double.json",
        "string.quoted.double.json.comments"
      ],
      "settings": {
        "foreground": "#CE9178"
      }
    },
    {
      "name": "JSON Number",
      "scope": [
        "constant.numeric.json",
        "constant.numeric.json.comments"
      ],
      "settings": {
        "foreground": "#B5CEA8"
      }
    },
    {
      "name": "JSON Constant",
      "scope": [
        "constant.language.boolean.json",
        "constant.language.null.json",
        "constant.language.boolean.json.comments",
        "constant.language.null.json.comments"
      ],
      "settings": {
        "foreground": "#569CD6"
      }
    },
    {
      "name": "JSON Escape",
      "scope": [
        "constant.character.escape.json",
        "constant.character.escape.json.comments"
      ],
      "settings": {
        "foreground": "#D7BA7D"
      }
    },
    {
      "name": "JSON Punctuation",
      "scope": [
        "punctuation.definition.dictionary",
        "punctuation.definition.array",
        "punctuation.separator.dictionary",
        "punctuation.separator.array"
      ],
      "settings": {
        "foreground": "#D4D4D4"
      }
    },
    {
      "name": "CSS Selector",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-class.css"
      ],
      "settings": {
        "foreground": "#D7BA7D"
      }
    },
    {
      "name": "CSS Property",
      "scope": [
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },
    {
      "name": "YAML TOML Section",
      "scope": [
        "entity.name.section.toml",
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#9CDCFE"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#F44747"
      }
    },
    {
      "name": "Diff Inserted",
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#B5CEA8"
      }
    },
    {
      "name": "Diff Deleted",
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#CE9178"
      }
    },
    {
      "name": "Diff Changed",
      "scope": "markup.changed",
      "settings": {
        "foreground": "#DCDCAA"
      }
    }
  ]
}
