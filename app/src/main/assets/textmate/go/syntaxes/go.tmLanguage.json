{
  "information_for_contributors": ["Go TextMate grammar for ZeroTermux, based on vscode-go and microsoft/vscode"],
  "name": "Go",
  "scopeName": "source.go",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.go",
          "match": "//.*$"
        },
        {
          "name": "comment.block.go",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "comment.block.go" } },
          "endCaptures": { "0": { "name": "comment.block.go" } }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.go",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.go", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.go",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.go", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.raw.go",
          "begin": "`",
          "end": "`"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.go",
          "match": "\\b(break|case|chan|const|continue|default|defer|else|fallthrough|for|func|go|goto|if|import|interface|map|package|range|return|select|struct|switch|type|var)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.go",
          "match": "\\b(append|cap|clear|close|complex|copy|delete|imag|len|make|max|min|new|panic|print|println|real|recover)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.builtin.go",
          "match": "\\b(bool|byte|complex64|complex128|error|float32|float64|int|int8|int16|int32|int64|rune|string|uint|uint8|uint16|uint32|uint64|uintptr|any|comparable)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.go",
          "match": "\\b(func)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.go" },
            "2": { "name": "entity.name.function.go" }
          }
        },
        {
          "name": "support.function.go",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.go",
          "match": "\\b(true|false|nil|iota)\\b"
        },
        {
          "name": "constant.numeric.integer.go",
          "match": "\\b(0x[0-9A-Fa-f_]+|0b[01_]+|0o[0-7_]+|[0-9][0-9_]*)\\b"
        },
        {
          "name": "constant.numeric.float.go",
          "match": "\\b[0-9][0-9_]*\\.[0-9_]*([eE][+-]?[0-9_]+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.go",
          "match": "(<-|:=|\\.\\.\\.|==|!=|<=|>=|&&|\\|\\||\\+\\+|--|[+\\-*/%&|^~<>!]=?|=)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.definition.go", "match": "[{}()\\[\\],;:.]" }
      ]
    }
  }
}
