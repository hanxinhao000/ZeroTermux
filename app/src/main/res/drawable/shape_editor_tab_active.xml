<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="#273040" />
            <stroke
                android:width="1dp"
                android:color="#3F4B5F" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item
        android:height="2dp"
        android:gravity="bottom"
        android:left="10dp"
        android:right="10dp">
        <shape>
            <solid android:color="#7AA2F7" />
            <corners android:radius="1dp" />
        </shape>
    </item>
</layer-list>
