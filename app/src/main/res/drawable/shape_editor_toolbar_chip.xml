<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#2D3746" />
            <stroke
                android:width="1dp"
                android:color="#52617A" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#1F2733" />
            <stroke
                android:width="1dp"
                android:color="#303A49" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</selector>
