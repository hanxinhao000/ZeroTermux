    <!-- Left menu JSON / validation -->
    <string name="zt_ai_left_menu_minimal_example"><![CDATA[<?xml version="1.0" encoding="utf-8"?>
<zt-menu>
    <group name="常用">
        <item tag="ZT设置"
            name="设置"
            click="java:com.termux.zerocore.config.mainmenu.config.ZTSettingsClickConfig" />
        <item tag="更新软件源"
            name="更新源"
            click="ztShell:pkg update"
            autoRunShell="true" />
    </group>
</zt-menu>]]></string>

    <string-array name="zt_ai_left_menu_item_notes">
        <item>tag 是备注标签，java: 项不要改 tag 含义</item>
        <item>name 为显示名；java: 项可只写 tag 不写 name</item>
        <item>icon 仅对非 java: 的 click 生效；java: 项 icon 无效</item>
        <item>dialogConfirm/dialogTitle/dialogMessage 仅 ztShell: 生效</item>
        <item>intentData 格式 key@@value</item>
        <item>commands: 格式 名称@@命令,名称@@命令；&amp;&amp; 写 &amp;amp;&amp;&amp;</item>
    </string-array>
    <string-array name="zt_ai_left_menu_forbidden">
        <item>click=\"pkg\" / \"mc\" / \"exit\" 等裸命令</item>
        <item>click=\"zt openpage …\" 应改用 java:ZTSettingsClickConfig 或 startActivity:</item>
        <item>编造不存在的 java:…ClickConfig 类名</item>
        <item>修改程序菜单/默认菜单/main_menu_path.xml</item>
    </string-array>
    <string-array name="zt_ai_left_menu_workflow">
        <item>1. get_zerotermux_left_menu 读取 xml_rules + builtin_menu_catalog</item>
        <item>2. 按用户需求从 catalog 复制 group/item，或按 click_types 示例构造</item>
        <item>3. update_zerotermux_left_menu create_menu_package=当前语言 AI 菜单名 + xml_content</item>
        <item>4. 默认不 switch_to_menu；用户手动切换查看</item>
    </string-array>

