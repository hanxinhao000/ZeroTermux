    <!-- Hints -->
    <string name="zt_ai_hint_beautify">文字模糊/字糊/看不清字→关闭 text_shadow_enabled；背景模糊/壁纸糊→调整 blur_enabled/blur_radius</string>
    <string name="zt_ai_hint_beautify_ui">雪花/下雪/snowflake/snow→set_zerotermux_config key=isSnowflakeShow value=true|false；粒子/粒子动画/下雨/particle/rain→key=isRainShow；二者互斥。侧栏背景图→mIsBackMenuVisible。用 set 控制，勿改菜单 XML</string>
    <string name="zt_ai_left_menu_rules_summary">创建菜单前必须先 get_zerotermux_left_menu 阅读 xml_rules 与 builtin_menu_catalog。click 必须使用固定前缀（java:/ztShell:/jumpUrl: 等），禁止 pkg/mc/exit 等裸命令。java: 项从内置 catalog 复制完整类名；tag 是备注不可删改含义；Shell 中 &amp;&amp; 写 &amp;amp;&amp;&amp;。优先从 catalog 挑选 item 组合，不要编造不存在的 Config 类。</string>
    <string name="zt_ai_left_menu_hint_extra"> 每次 create_menu_package 使用当前语言的 AI 菜单名（如 AI创建 / AI Created）新建独立包。</string>
    <string name="zt_ai_left_menu_example_keyword">示例</string>
    <string name="zt_ai_pkg_source_hint">换源默认清华源(tsinghua)。先 list_zerotermux_pkg_sources 给出方案让用户选，用户明确同意后再 switch_zerotermux_pkg_source 且 user_confirmed=true。会修改 sources.list 并 apt update/upgrade，须告知会覆盖现有源配置。</string>

    <!-- Tool descriptions -->
    <string name="zt_ai_tool_list_capabilities">列举 ZeroTermux 设置键、美化项、终端特效键、openpage 页面与 zt 命令。不确定时先调用。category: all|settings|beautify|beautify_ui|pages|zt_commands|left_menu|pkg_source</string>
    <string name="zt_ai_tool_get_config">读取 ZeroTermux 用户设置(ZTUserBean)、美化 SaveData 与终端特效(isSnowflakeShow/isRainShow)。</string>
    <string name="zt_ai_tool_set_config">设置一项 ZeroTermux 配置。布尔值 true/false 或 1/0。雪花/粒子: isSnowflakeShow / isRainShow（互斥）。危险项如 isInternalPassage 须先确认用户。</string>
    <string name="zt_ai_tool_open_page">按 page_id 打开 App 内页面（同 zt openpage）。示例: zt_settings, zero_termux_settings, agent_ai_settings, editor</string>
    <string name="zt_ai_tool_run_zt">经本地 Socket 执行 zt 命令（优先于终端）。示例: help, toast hello, openleft, openpage list, reboot, x11status。reboot 等危险操作须用户确认。</string>
    <string name="zt_ai_tool_get_left_menu">读取 Menu 菜单列表、xml_rules 与 builtin_menu_catalog。创建菜单 XML 前必须先调用。</string>
    <string name="zt_ai_tool_update_left_menu">创建/更新 AI 菜单包（合法 zt-menu XML）。须先 get_zerotermux_left_menu。click 须用 java:/ztShell:/jumpUrl: 等前缀，禁止裸 pkg/mc/exit。</string>
    <string name="zt_ai_tool_list_pkg_sources">列举 Termux APT 换源方案（同左侧「切换源」）。默认 tsinghua，先展示选项再切换。</string>
    <string name="zt_ai_tool_switch_pkg_source">用户选定源并明确同意后切换 APT 源。须 user_confirmed=true。会覆盖 sources.list 并 apt update。</string>
    <string name="zt_ai_tool_read_terminal">读取当前终端可见屏幕。描述终端状态、安装进度或命令输出前必须先调用，禁止猜测。</string>
    <string name="zt_ai_tool_send_command">向终端发送命令（默认追加换行）。默认等待 shell 提示符（最长约 10 分钟）。仅依据返回的快照描述结果。</string>
    <string name="zt_ai_tool_send_key">向终端发送特殊按键或组合键。</string>
    <string name="zt_ai_tool_run_zt_command">经终端执行 zt 命令（等同输入 zt …）。须依据终端快照判断结果。示例: help, openleft, openpage zt_settings</string>

