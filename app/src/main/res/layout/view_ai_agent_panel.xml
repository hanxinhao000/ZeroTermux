<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ai_agent_panel_card"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/color_ai_panel_bg"
    app:cardCornerRadius="6dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_margin="3dp"
            app:cardBackgroundColor="@color/color_55000000"
            app:cardCornerRadius="3dp"
            app:cardElevation="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/ai_agent_panel_reset"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="4dp"
                    android:contentDescription="@string/zt_agent_ai_reset_panel_desc"
                    android:padding="6dp"
                    android:src="@drawable/ic_agent_restore" />

                <TextView
                    android:id="@+id/ai_agent_panel_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:layout_centerVertical="true"
                    android:text="@string/zt_ai_agent_panel_title_bar"
                    android:textColor="@color/white"
                    android:textSize="17sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/ai_agent_panel_settings"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:contentDescription="@string/zt_agent_ai_settings_title"
                        android:padding="6dp"
                        android:src="@drawable/ic_agent_settings" />

                    <ImageView
                        android:id="@+id/ai_agent_panel_open_menu"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:contentDescription="@string/zt_ai_agent_panel_open_menu"
                        android:padding="6dp"
                        android:src="@drawable/ic_agent_side_panel" />

                    <ImageView
                        android:id="@+id/ai_agent_panel_close"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:contentDescription="@string/cancel"
                        android:padding="6dp"
                        android:src="@drawable/ic_agent_close" />
                </LinearLayout>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/ai_agent_panel_context_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/zt_ai_agent_panel_context_label"
                android:textColor="@color/md_grey_500"
                android:textSize="12sp"
                android:visibility="gone" />

            <com.termux.zerocore.ai.agent.ZtAgentSelectableTextView
                android:id="@+id/ai_agent_panel_context_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@color/color_55000000"
                android:padding="8dp"
                android:textColor="@color/color_ffffff"
                android:textIsSelectable="true"
                android:textSelectHandle="@drawable/ai_agent_text_select_handle_middle"
                android:textSelectHandleLeft="@drawable/ai_agent_text_select_handle_left"
                android:textSelectHandleRight="@drawable/ai_agent_text_select_handle_right"
                android:textSize="13sp"
                android:visibility="gone" />

            <ScrollView
                android:id="@+id/ai_agent_panel_scroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/ai_agent_panel_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="8dp"
                        android:text="@string/zt_ai_agent_panel_empty"
                        android:textColor="@color/md_grey_500"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:id="@+id/ai_agent_panel_messages"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone" />
                </LinearLayout>
            </ScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.termux.zerocore.ai.agent.ZtAgentSelectableEditText
                    android:id="@+id/ai_agent_panel_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/shape_ai_agent_input"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:hint="@string/zt_ai_agent_panel_hint"
                    android:imeOptions="actionSend"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLines="4"
                    android:minHeight="44dp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp"
                    android:textColor="@color/color_ffffff"
                    android:textColorHint="@color/md_grey_500"
                    android:textCursorDrawable="@drawable/ai_agent_text_cursor"
                    android:textSelectHandle="@drawable/ai_agent_text_select_handle_middle"
                    android:textSelectHandleLeft="@drawable/ai_agent_text_select_handle_left"
                    android:textSelectHandleRight="@drawable/ai_agent_text_select_handle_right"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/ai_agent_panel_send"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/shape_editor_action_save"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:gravity="center"
                    android:minWidth="70dp"
                    android:paddingHorizontal="14dp"
                    android:text="@string/zt_ai_agent_panel_send"
                    android:textColor="@color/color_ffffff"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
