<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E1E"
    android:orientation="vertical"
    tools:context=".zerocore.activity.EditTextActivity">

    <LinearLayout
        android:id="@+id/editor_toolbar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_alignParentTop="true"
        android:background="@drawable/shape_editor_toolbar_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="4dp"
        android:paddingTop="2dp"
        android:paddingRight="4dp"
        android:paddingBottom="2dp">

        <ImageView
            android:id="@+id/editor_menu"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/shape_editor_toolbar_button"
            android:contentDescription="@string/editor_toolbar_menu"
            android:padding="6dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_editor_menu"
            android:tint="#F4F4F4" />

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="3dp">

            <ImageView
                android:id="@+id/editor_action_run"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/shape_editor_toolbar_button"
                android:contentDescription="@string/editor_toolbar_run"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_editor_run"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/editor_action_run_loading"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:indeterminateTint="#4CAF50"
                android:visibility="gone" />
        </FrameLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/editor_action_files"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="3dp"
            android:background="@drawable/shape_editor_toolbar_button"
            android:contentDescription="@string/editor_toolbar_files"
            android:padding="6dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_editor_save"
            android:tint="#F4F4F4" />

        <ImageView
            android:id="@+id/editor_action_undo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="3dp"
            android:background="@drawable/shape_editor_toolbar_button"
            android:contentDescription="@string/editor_toolbar_undo"
            android:padding="6dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_editor_undo"
            android:tint="#F4F4F4" />

        <ImageView
            android:id="@+id/editor_action_redo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="3dp"
            android:background="@drawable/shape_editor_toolbar_button"
            android:contentDescription="@string/editor_toolbar_redo"
            android:padding="6dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_editor_redo"
            android:tint="#F4F4F4" />

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="3dp">

            <ImageView
                android:id="@+id/editor_action_android_build"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/shape_editor_toolbar_button"
                android:contentDescription="@string/editor_toolbar_android_build"
                android:padding="5dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_editor_android_build"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/editor_action_android_build_loading"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:indeterminateTint="#4CAF50"
                android:visibility="gone" />
        </FrameLayout>

        <ImageView
            android:id="@+id/editor_action_terminal"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="3dp"
            android:background="@drawable/shape_editor_toolbar_button"
            android:contentDescription="@string/editor_toolbar_terminal"
            android:padding="6dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_editor_terminal"
            android:tint="#F4F4F4" />

        <ImageView
            android:id="@+id/editor_action_more"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginLeft="3dp"
            android:background="@drawable/shape_editor_toolbar_button"
            android:contentDescription="@string/editor_toolbar_more"
            android:padding="6dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_editor_more"
            android:tint="#F4F4F4" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/editor_tab_bar"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_below="@id/editor_toolbar"
        android:background="@drawable/shape_editor_tab_bar_bg"
        android:fillViewport="false"
        android:overScrollMode="ifContentScrolls"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/editor_tabs_container"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="4dp"
            android:paddingRight="4dp" />
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/editor_terminal_panel"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_alignParentBottom="true"
        android:background="#141414"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/editor_terminal_resize_handle"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <View
                android:layout_width="48dp"
                android:layout_height="4dp"
                android:background="#555555" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="10dp"
            android:paddingRight="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/editor_terminal_title"
                android:textColor="#B0B0B0"
                android:textSize="12sp" />

            <ImageView
                android:id="@+id/editor_terminal_hide"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/shape_editor_toolbar_button"
                android:contentDescription="@string/editor_terminal_hide"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_editor_hide"
                android:tint="#CCCCCC" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <com.termux.view.TerminalView
                android:id="@+id/editor_terminal_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:importantForAutofill="no"
                android:scrollbarThumbVertical="@drawable/terminal_scroll_shape"
                android:scrollbars="vertical" />

            <com.termux.zerocore.editor.EditorTerminalInputView
                android:id="@+id/editor_terminal_input"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:importantForAutofill="no" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/editor_symbol_bar"
        android:layout_width="match_parent"
        android:layout_height="66dp"
        android:layout_alignParentBottom="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="8dp"
        android:paddingTop="8dp"
        android:paddingRight="8dp"
        android:paddingBottom="8dp">

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:fillViewport="false"
            android:overScrollMode="ifContentScrolls"
            android:scrollbars="none">

            <io.github.rosemoe.sora.widget.SymbolInputView
                android:id="@+id/editor_symbol_input"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </HorizontalScrollView>
    </LinearLayout>

    <RelativeLayout
        android:id="@+id/editor_content_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/editor_symbol_bar"
        android:layout_below="@+id/editor_tab_bar">

        <EditText
            android:id="@+id/edit_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="3dp"
            android:gravity="left"
            android:padding="10dp"
            android:text=""
            android:textColor="@color/color_ffffff"
            android:textSize="15sp"
            android:visibility="gone" />

        <io.github.rosemoe.sora.widget.CodeEditor
            android:id="@+id/code_editor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:text="@string/code_editor_loading"
            app:textSize="13sp" />

        <RelativeLayout
            android:id="@+id/editor_preview_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#1E1E1E"
            android:visibility="gone">

            <ImageView
                android:id="@+id/editor_image_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:background="#1E1E1E"
                android:contentDescription="@string/editor_image_preview"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:visibility="gone" />

            <WebView
                android:id="@+id/editor_svg_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#1E1E1E"
                android:visibility="gone" />
        </RelativeLayout>
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/editor_sidebar"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_alignParentBottom="true"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        android:background="@drawable/shape_editor_sidebar_bg"
        android:elevation="12dp"
        android:orientation="vertical"
        android:paddingLeft="10dp"
        android:paddingTop="8dp"
        android:paddingRight="10dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/editor_sidebar_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/ok"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_editor_action_save"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:text="@string/edit_save"
                android:textColor="@color/color_ffffff"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/cancel"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/shape_editor_action_exit"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:text="@string/notification_action_exit"
                android:textColor="@color/color_ffffff"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/editor_settings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/shape_editor_icon_button"
                android:contentDescription="@string/editor_settings"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:text="⚙"
                android:textColor="#C5C5C5"
                android:textSize="16sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/editor_svg_mode_toggle"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/shape_editor_symbol_key"
            android:foreground="?android:attr/selectableItemBackground"
            android:gravity="center"
            android:text="@string/editor_svg_preview_mode"
            android:textColor="#D4D4D4"
            android:textSize="13sp"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/sidebar_page_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/sidebar_main_page"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/shape_editor_slider_track"
            android:orientation="horizontal"
            android:paddingLeft="3dp"
            android:paddingRight="3dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp">

            <TextView
                android:id="@+id/sidebar_file_tab"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/shape_editor_slider_thumb"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:text="@string/editor_sidebar_files"
                android:textColor="#F5F5F5"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/sidebar_search_tab"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/shape_editor_slider_thumb_inactive"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:text="@string/editor_sidebar_search"
                android:textColor="#9D9D9D"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sidebar_file_panel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingTop="10dp">

            <TextView
                android:id="@+id/sidebar_file_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:background="@drawable/shape_editor_path_chip"
                android:ellipsize="middle"
                android:gravity="center_vertical"
                android:paddingLeft="10dp"
                android:paddingTop="8dp"
                android:paddingRight="10dp"
                android:paddingBottom="8dp"
                android:singleLine="true"
                android:textColor="#CCCCCC"
                android:textSize="12sp"
                tools:text="/sdcard/project" />

            <com.termux.zerocore.editor.EditorFileTreeScrollView
                android:id="@+id/sidebar_file_tree_scroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/shape_editor_sidebar_panel"
                android:fillViewport="false"
                android:overScrollMode="never"
                android:scrollbars="horizontal">

                <com.termux.zerocore.editor.EditorFileTreeListView
                    android:id="@+id/sidebar_file_tree"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:cacheColorHint="#00000000"
                    android:clipToPadding="false"
                    android:divider="#2D2D30"
                    android:dividerHeight="1dp"
                    android:listSelector="@drawable/shape_editor_list_selector"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:scrollbars="vertical" />
            </com.termux.zerocore.editor.EditorFileTreeScrollView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sidebar_search_panel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/sidebar_search_input"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:background="@drawable/shape_editor_input_field"
                android:hint="@string/editor_sidebar_search_hint"
                android:imeOptions="actionSearch"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:singleLine="true"
                android:textColor="#F5F5F5"
                android:textColorHint="#858585"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/sidebar_replace_input"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/shape_editor_input_field"
                android:hint="@string/edit_replace_hint"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:singleLine="true"
                android:textColor="#F5F5F5"
                android:textColorHint="#858585"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/sidebar_regex_toggle"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_marginRight="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/shape_editor_toolbar_chip"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:gravity="center"
                    android:text="@string/editor_sidebar_regex"
                    android:textColor="@color/color_ffffff"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/sidebar_case_toggle"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:background="@drawable/shape_editor_toolbar_chip"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:gravity="center"
                    android:text="@string/editor_sidebar_match_case"
                    android:textColor="@color/color_ffffff"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/sidebar_prev"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_marginRight="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/shape_editor_toolbar_chip"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:gravity="center"
                    android:text="↑"
                    android:textColor="@color/color_ffffff"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/sidebar_next"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_marginRight="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/shape_editor_toolbar_chip"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:gravity="center"
                    android:text="↓"
                    android:textColor="@color/color_ffffff"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/sidebar_replace_one"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_marginRight="4dp"
                    android:layout_weight="2"
                    android:background="@drawable/shape_editor_toolbar_chip"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:gravity="center"
                    android:text="@string/edit_replace"
                    android:textColor="@color/color_ffffff"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/sidebar_replace_all"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="2"
                    android:background="@drawable/shape_editor_toolbar_chip"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:gravity="center"
                    android:text="@string/edit_replace_all"
                    android:textColor="@color/color_ffffff"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/sidebar_search_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:paddingBottom="6dp"
                android:text="@string/editor_sidebar_search_empty"
                android:textColor="#858585"
                android:textSize="12sp" />

            <ListView
                android:id="@+id/sidebar_search_results"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/shape_editor_sidebar_panel"
                android:cacheColorHint="#00000000"
                android:clipToPadding="false"
                android:divider="#2D2D30"
                android:dividerHeight="1dp"
                android:listSelector="@drawable/shape_editor_list_selector"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:scrollbars="none" />
        </LinearLayout>

            </LinearLayout>

            <ScrollView
                android:id="@+id/sidebar_project_page"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:overScrollMode="ifContentScrolls"
                android:scrollbars="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="12dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/editor_sidebar_project_path_label"
                        android:textColor="#9D9D9D"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/sidebar_project_path"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="14dp"
                        android:background="@drawable/shape_editor_path_chip"
                        android:ellipsize="middle"
                        android:gravity="center_vertical"
                        android:paddingLeft="10dp"
                        android:paddingTop="8dp"
                        android:paddingRight="10dp"
                        android:paddingBottom="8dp"
                        android:singleLine="true"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp"
                        tools:text="/data/data/com.termux/files/home" />

                    <TextView
                        android:id="@+id/sidebar_create_java"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/shape_editor_symbol_key"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp"
                        android:text="@string/editor_sidebar_create_java"
                        android:textColor="#F5F5F5"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/sidebar_create_c"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/shape_editor_symbol_key"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp"
                        android:text="@string/editor_sidebar_create_c"
                        android:textColor="#F5F5F5"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/sidebar_create_python"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/shape_editor_symbol_key"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp"
                        android:text="@string/editor_sidebar_create_python"
                        android:textColor="#F5F5F5"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/sidebar_create_php"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/shape_editor_symbol_key"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp"
                        android:text="@string/editor_sidebar_create_php"
                        android:textColor="#F5F5F5"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/sidebar_create_node"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/shape_editor_symbol_key"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp"
                        android:text="@string/editor_sidebar_create_node"
                        android:textColor="#F5F5F5"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/sidebar_create_android"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/shape_editor_symbol_key"
                        android:foreground="?android:attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp"
                        android:text="@string/editor_sidebar_create_android"
                        android:textColor="#F5F5F5"
                        android:textSize="14sp"
                        android:visibility="gone" />
                </LinearLayout>
            </ScrollView>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/sidebar_bottom_switch"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/shape_editor_slider_track"
            android:orientation="horizontal"
            android:paddingLeft="3dp"
            android:paddingRight="3dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp">

            <TextView
                android:id="@+id/sidebar_page_browser_tab"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/shape_editor_slider_thumb"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:text="@string/editor_sidebar_page_browser"
                android:textColor="#F5F5F5"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/sidebar_page_project_tab"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/shape_editor_slider_thumb_inactive"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center"
                android:text="@string/editor_sidebar_page_project"
                android:textColor="#9D9D9D"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
